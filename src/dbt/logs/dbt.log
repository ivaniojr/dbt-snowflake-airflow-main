    COALESCE(T.TOTAL_UST, 0)                                   AS TOTAL_UST,
    S.DW_INGESTED_AT                                           AS DT_CARGA
FROM DRAGON_DB.munka_stg.stg_sprint S
LEFT JOIN (
    SELECT
