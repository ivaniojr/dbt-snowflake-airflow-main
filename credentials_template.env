# ---------------------------------------------------------------------
# 1. CREDENCIAIS SNOWFLAKE (Uso no dbt e no Airflow)
# ---------------------------------------------------------------------
DBT_SNOWFLAKE_ACCOUNT=sfedu02-gfb24387
DBT_SNOWFLAKE_USER=DRAGON
DBT_SNOWFLAKE_PASSWORD=SuaSenhaSeUsarSenha
DBT_SNOWFLAKE_DATABASE=DRAGON_DB
DBT_SNOWFLAKE_ROLE=TRAINING_ROLE
DBT_SNOWFLAKE_WAREHOUSE=DBT_WH
DBT_SNOWFLAKE_SCHEMA=JM
# Chave privada RSA (caminho relativo dentro da pasta src/dbt/)
DBT_SNOWFLAKE_PRIVATE_KEY_PATH=rsa_key.p8

# ---------------------------------------------------------------------
# 2. CREDENCIAIS AWS S3 (Ingestão do S3 para Snowflake RAW no Airflow)
# ---------------------------------------------------------------------
AWS_ACCESS_KEY_ID=SUA_ACCESS_KEY_ID_AQUI
AWS_SECRET_ACCESS_KEY=SUA_SECRET_ACCESS_KEY_AQUI
AWS_DEFAULT_REGION=us-east-2
S3_BUCKET_NAME=munka-dev-070980587239-us-east-2

# ---------------------------------------------------------------------
# 3. CONFIGURAÇÕES DO APACHE AIRFLOW
# ---------------------------------------------------------------------
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
AIRFLOW_CUSTOM_IMAGE_NAME=airflow-dbt-snowflake:2.10.0
